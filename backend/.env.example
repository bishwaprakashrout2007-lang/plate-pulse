# PlatePulse Backend Configuration
PORT=8000
HOST=0.0.0.0

# Database Settings
MONGO_URI=mongodb://localhost:27017
DB_NAME=platepulse

# Security and Auth
JWT_SECRET=super_secret_jwt_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email SMTP Configuration (Gmail recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@platepulse.org

# Cloudinary Integration
CLOUDINARY_CLOUD_NAME=dummy_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=dummy_api_secret

# ZegoCloud Verification Call Settings
ZEGO_APP_ID=123456789
ZEGO_SERVER_SECRET=dummy_zegocloud_server_secret_key

# Firebase Integration (Admin Service Account - optional if using raw JWT)
# FIREBASE_SERVICE_ACCOUNT_JSON=path/to/firebase-credentials.json
